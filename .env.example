# LLM Scribe Pro Configuration
# Copy this file to .env and fill in your values

# Security (CRITICAL: Change this to a random string!)
LLM_SCRIBE_SALT=your_custom_secure_salt_here

# Optional: Data Directory (Default: %APPDATA%/LLMScribePro on Windows)
# LLM_SCRIBE_DATA_DIR=C:/Path/To/Your/Data

# UI Settings
# APP_NAME=LLM Scribe Pro Custom
